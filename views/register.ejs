<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Register - Impulse Guard</title>
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
<style>
  body { font-family: 'Inter', sans-serif; background: #0B1326; }
  input { background: #171F33; color: white; }
</style>
</head>
<body>

<div class="min-h-screen flex flex-col md:flex-row text-white">

  <!-- LEFT SIDE -->
  <div class="hidden md:flex md:w-1/2 flex-col justify-between p-10 bg-gradient-to-br from-[#060E20] to-[#111c44]">
    <div class="space-y-6 text-center max-w-xl mx-auto">
      <p class="text-gray-400 text-sm mb-6">Impulse Guard</p>

      <h1 class="text-5xl font-semibold leading-tight text-center">
        The <span class="text-[#9AE6FF]">Ethereal</span><br />
        Guardian of Your<br />Assets.
      </h1>

      <p class="text-gray-300 max-w-md text-sm leading-relaxed mx-auto">
        Advanced AI-driven impulse protection. We sit between your intent and your capital, ensuring every transaction is aligned with your future.
      </p>
    </div>

    <div class="flex justify-center">
      <div class="w-[448px] h-[228px] rounded-2xl overflow-hidden bg-[#0F2A3D] shadow-[0_0_80px_rgba(56,189,248,0.25)]">
        <img src="/ai-image.png" alt="AI Graphic" class="w-full h-full object-cover" onerror="this.style.display='none'">
      </div>
    </div>

    <div class="flex gap-4 max-w-xl mx-auto w-full">
      <div class="flex-1 bg-[#171F33] p-5 rounded-2xl">
        <p class="text-sm font-medium">Secure Protocol</p>
        <p class="text-xs text-gray-400 mt-1">Multi-layered encryption for every tier.</p>
      </div>

      <div class="flex-1 bg-[#171F33] p-5 rounded-2xl">
        <p class="text-sm font-medium">Smart Analytics</p>
        <p class="text-xs text-gray-400 mt-1">Real-time spending behavioral patterns.</p>
      </div>
    </div>
  </div>

  <!-- RIGHT SIDE -->
  <div class="w-full md:w-1/2 flex items-center justify-center px-6 py-10 bg-[#0B1326]">
    <div class="w-full max-w-md">

      <h2 class="text-3xl font-semibold">Create Account</h2>
      <p class="text-gray-400 text-sm mt-2">
        Enter your details to create your premium dashboard.
      </p>

      <% if (locals.error && error) { %>
        <script>alert('<%= error %>');</script>
      <% } %>

      <!-- SOCIAL BUTTONS -->
      <div class="flex gap-4 mt-6">
        <button class="flex-1 h-12 rounded-full bg-[#0F2A3D] border border-white/5 hover:bg-white/10 transition">
          Google
        </button>
        <button class="flex-1 h-12 rounded-full bg-[#0F2A3D] border border-white/5 hover:bg-white/10 transition">
          Apple
        </button>
      </div>

      <!-- DIVIDER -->
      <div class="flex items-center gap-3 my-6 text-gray-500 text-xs">
        <div class="flex-1 h-px bg-white/10"></div>
        OR CONTINUE WITH EMAIL
        <div class="flex-1 h-px bg-white/10"></div>
      </div>

      <form action="/auth/register" method="POST">
        <!-- NAME -->
        <div class="mb-4">
          <label class="text-xs text-gray-400">FULL NAME</label>
          <input
            type="text"
            name="name"
            placeholder="John Doe"
            required
            class="w-full mt-2 h-12 px-4 rounded-xl border border-white/5 focus:outline-none focus:ring-2 focus:ring-cyan-400"
          />
        </div>

        <!-- EMAIL -->
        <div class="mb-4">
          <label class="text-xs text-gray-400">EMAIL ADDRESS</label>
          <input
            type="email"
            name="email"
            placeholder="name@company.com"
            required
            class="w-full mt-2 h-12 px-4 rounded-xl border border-white/5 focus:outline-none focus:ring-2 focus:ring-cyan-400"
          />
        </div>

        <!-- PASSWORD -->
        <div class="mb-4">
          <label class="text-xs text-gray-400">PASSWORD</label>
          <input
            type="password"
            name="password"
            placeholder="••••••••"
            required
            class="w-full mt-2 h-12 px-4 rounded-xl border border-white/5 focus:outline-none focus:ring-2 focus:ring-cyan-400"
          />
        </div>

        <!-- BUTTON -->
        <button type="submit" class="w-full h-12 rounded-full mt-4 text-[#0B1326] font-semibold bg-gradient-to-r from-[#C0C1FF] to-[#4B4DD8] hover:brightness-110 shadow-[0_0_30px_rgba(75,77,216,0.6)] transition">
          Create Account →
        </button>
      </form>

      <!-- FOOTER -->
      <p class="text-center text-sm text-gray-400 mt-6">
        Already have an account? <a href="/login" class="text-[#4FD1C5] cursor-pointer hover:underline">Sign In</a>
      </p>

    </div>
  </div>
</div>

</body>
</html>
